{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(node --version:*)",
      "Bash(npm:*)",
      "Bash(python:*)",
      "Bash(git:*)",
      "Read",
      "Grep",
      "Glob",
      "Edit",
      "Write",
      "Bash"
    ],
    "mode": "autonomous"
  },
  "model": "sonnet",
  "enabledMcpjsonServers": [
    "antv-chart",
    "bq-ax",
    "bq-member",
    "github",
    "memory",
    "notion-epic-tracker"
  ],
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true,
    "bkit@bkit-marketplace": true,
    "oh-my-claudecode@omc": true
  },
  "extraKnownMarketplaces": {
    "omc": {
      "source": {
        "source": "git",
        "url": "https://github.com/Yeachan-Heo/oh-my-claudecode.git"
      }
    }
  },
  "effortLevel": "medium",
  "skipDangerousModePermissionPrompt": true
}
